# Copy this file to .env and fill in the values. Never commit .env.

# --- Data providers ---
FMP_API_KEY=your_fmp_api_key_here
FRED_API_KEY=your_fred_api_key_here
EDGAR_USER_AGENT=Your Name contact@example.com

# --- Feature pipeline (optional tuning) ---
ALPHA_WORKERS=4
USE_PARALLEL_ALPHAS=1

# --- Dashboard ---
# Path to the SLIM dashboard DB. Leave UNSET to read the full local database
# (the default is data/market_data.duckdb).
#
# 🛑 NEVER set this to data/market_data.duckdb. On a machine that pulls from R2
# this path is the DOWNLOAD DESTINATION — pointing it at the main DB overwrites
# 23 years of history with an 8-month slim window. That happened on 2026-07-18.
DASHBOARD_DB_PATH=data/dashboard.duckdb

# --- Cloudflare R2 (slim DB sync) ---
# Data flow is ONE-WAY:  local main DB → slim DB → R2 → remote viewer.
# These credentials authorise the local→R2 UPLOAD (scripts/sync_dashboard_db.py).
# They do NOT authorise a download — see DASHBOARD_PULL_FROM_R2 below.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=quantamental
R2_JURI_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# --- Remote viewer ONLY (Streamlit Cloud) ---
# Set to 1 *only* on the deployed cloud app: it opts that process into pulling
# the slim DB down from R2. Leave UNSET on the dev box and on sh019 — both hold
# R2 credentials, and gating the pull on credentials alone is precisely what
# destroyed the main DB. Credentials mean "can reach R2", not "am the viewer".
# DASHBOARD_PULL_FROM_R2=1
