# Copy this file to .env and fill in the values. Never commit .env.

# --- Data providers ---
FMP_API_KEY=your_fmp_api_key_here
FRED_API_KEY=your_fred_api_key_here
EDGAR_USER_AGENT=Your Name contact@example.com

# --- Feature pipeline (optional tuning) ---
ALPHA_WORKERS=4
USE_PARALLEL_ALPHAS=1

# --- Dashboard ---
# Local path to the slim dashboard DB (defaults to data/market_data.duckdb if unset)
DASHBOARD_DB_PATH=data/dashboard.duckdb

# --- Cloudflare R2 (slim DB sync) ---
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=quantamental
R2_JURI_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
